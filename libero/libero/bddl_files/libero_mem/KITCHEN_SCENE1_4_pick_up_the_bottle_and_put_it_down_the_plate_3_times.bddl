(define (problem LIBERO_Kitchen_Tabletop_Manipulation)
  (:domain robosuite)
  (:language pick up the bottle and put it down the plate 3 times)
    (:regions
      (wooden_cabinet_init_region
          (:target kitchen_table)
          (:ranges (
              (-0.01 -0.29 0.01 -0.28)
            )
          )
          (:yaw_rotation (
              (3.141592653589793 3.141592653589793)
            )
          )
      )
      (plate_random_init_region_1
          (:target kitchen_table)
          (:ranges (
              (-0.25 -0.15 0.12 -0.01)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )

      (plate_random_init_region_2
          (:target kitchen_table)
          (:ranges (
              (-0.25 0.05 0.12 0.20)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )

      (plate_random_init_region_3
          (:target kitchen_table)
          (:ranges (
              (-0.25 -0.15 0.12 0.20)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )

      (plate_random_init_region_4
          (:target kitchen_table)
          (:ranges (
              (-0.25 -0.15 0.12 0.20)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )

      (akita_black_bowl_front_init_region
          (:target kitchen_table)
          (:ranges (
              (0.07500000000000001 0.050 0.125 0.175)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (akita_black_bowl_back_init_region
          (:target kitchen_table)
          (:ranges (
              (-0.400 0.050 -0.350 0.250)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (top_side
          (:target wooden_cabinet_1)
      )
      (top_region
          (:target wooden_cabinet_1)
      )
      (middle_region
          (:target wooden_cabinet_1)
      )
      (bottom_region
          (:target wooden_cabinet_1)
      )
    )

  (:fixtures
    kitchen_table - kitchen_table
    wooden_cabinet_1 - wooden_cabinet
  )

  (:objects
    akita_black_bowl_1 - akita_black_bowl
    wine_bottle_1 - wine_bottle
    plate_1 plate_2 plate_3 - plate
  )

  (:obj_of_interest
    akita_black_bowl_1
    plate_1
  )

  (:init
    (On wooden_cabinet_1 kitchen_table_wooden_cabinet_init_region)
    (On plate_1 kitchen_table_plate_random_init_region_1)
    (On plate_2 kitchen_table_plate_random_init_region_2)
    (On plate_3 kitchen_table_plate_random_init_region_3)
    (On akita_black_bowl_1 plate_1)
    (On wine_bottle_1 plate_2)
  )

  (:goal
    (Sequence
        (And (On wine_bottle_1 plate_2))
        (And (On wine_bottle_1 plate_2))
        (And (On wine_bottle_1 plate_2))
    )
  )

)
