  (:objects
    butter_1 - butter
    chocolate_pudding_1 - chocolate_pudding
    plate_1 - plate
    tomato_sauce_1 - tomato_sauce
  )

  (:obj_of_interest
    short_cabinet_1
    butter_1
    plate_1
    tomato_sauce_1
  )

  (:init
    (On short_cabinet_1 coffee_table_short_cabinet_init_region)
    (On butter_1 coffee_table_butter_init_region)
    (On plate_1 coffee_table_plate_init_region)
    (On tomato_sauce_1 coffee_table_tomato_sauce_init_region)
    (On chocolate_pudding_1 coffee_table_chocolate_pudding_init_region)
  )

  (:goal
    (And (On short_cabinet_1 coffee_table_short_cabinet_init_region) (In butter_1 short_cabinet_1_middle_region) (On plate_1 coffee_table_plate_init_region) (On tomato_sauce_1 coffee_table_tomato_sauce_init_region))
  )

)
